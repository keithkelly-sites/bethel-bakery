---
import { Font, Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import logoImg from '../assets/images/logo.png';

interface Props {
  title: string;
  description?: string;
  darkHeader?: boolean;
  ogTitle?: string;
  ogDescription?: string;
  canonicalPath?: string;
}

const { title, description = 'Bethel Bakery — a proud family-owned bakery since 1955. Wedding cakes, custom cakes, cookies, cupcakes, and more in the South Hills of Pittsburgh.', darkHeader = false, ogTitle, ogDescription, canonicalPath } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = 'https://bethel-bakery.keithkelly.dev';
const canonicalUrl = `${siteUrl}${canonicalPath || currentPath}`;
const ogTitleFinal = ogTitle || title;
const ogDescFinal = ogDescription || description;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitleFinal} />
    <meta property="og:description" content={ogDescFinal} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteUrl}/images/og-image.jpg`} />
    <meta property="og:site_name" content="Bethel Bakery" />

    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <header class={`site-header ${darkHeader ? 'site-header--dark' : ''}`} id="site-header">
      <div class="header-inner">
        <a href="/" class="header-logo">
          <Image src={logoImg} alt="Bethel Bakery" width={44} height={44} loading="eager" />
          <span class="header-logo-text">Bethel Bakery</span>
        </a>
        <nav class="header-nav" aria-label="Main navigation">
          <a href="/about" aria-current={currentPath === '/about/' || currentPath === '/about' ? 'page' : undefined}>About</a>
          <a href="/weddings" aria-current={currentPath === '/weddings/' || currentPath === '/weddings' ? 'page' : undefined}>Weddings</a>
          <a href="/contact" aria-current={currentPath === '/contact/' || currentPath === '/contact' ? 'page' : undefined}>Contact</a>
          <a href="https://bethelbakery.bakesmart.com/" target="_blank" rel="noopener noreferrer" class="nav-cta">Order Online</a>
        </nav>
        <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation" aria-hidden="true">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/weddings">Weddings</a>
      <a href="/contact">Contact</a>
      <a href="https://bethelbakery.bakesmart.com/" target="_blank" rel="noopener noreferrer" class="mobile-cta">Order Online</a>
    </nav>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <Image src={logoImg} alt="Bethel Bakery" width={60} height={60} loading="lazy" />
          <p>Three generations of baking life sweeter since 1955.</p>
          <div class="footer-social">
            <a href="https://www.facebook.com/BethelBakery/" target="_blank" rel="noopener noreferrer">Facebook</a>
            <a href="https://www.instagram.com/bethelbakery/" target="_blank" rel="noopener noreferrer">Instagram</a>
            <a href="https://x.com/BethelBakery" target="_blank" rel="noopener noreferrer">X</a>
          </div>
        </div>
        <div class="footer-location">
          <h3>Bethel Park</h3>
          <address>
            5200 Brightwood Road<br />
            Bethel Park, PA 15102<br /><br />
            Mon-Fri: 7 a.m. - 6 p.m.<br />
            Saturday: 7 a.m. - 5 p.m.<br />
            Sunday: Closed
          </address>
          <p style="margin-top: 0.5rem"><a href="tel:4128356658">412-835-6658</a></p>
        </div>
        <div class="footer-location">
          <h3>North Strabane</h3>
          <address>
            2500 Washington Road<br />
            North Strabane, PA 15317<br /><br />
            Mon-Fri: 8 a.m. - 6 p.m.<br />
            Saturday: 9 a.m. - 5 p.m.<br />
            Sunday: Closed
          </address>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; {new Date().getFullYear()} Bethel Bakery. All rights reserved.</span>
        <a href="/contact">Contact Us</a>
      </div>
    </footer>

    <script>
      document.documentElement.classList.add('js-ready');

      // Re-initialize on every page load (including view transitions)
      document.addEventListener('astro:page-load', () => {
        // Header scroll effect — re-query DOM after swap
        const header = document.getElementById('site-header');
        const onScroll = () => {
          if (window.scrollY > 60) {
            header?.classList.add('scrolled');
          } else {
            header?.classList.remove('scrolled');
          }
        };
        // Remove previous listener by using a named function on the window
        window.removeEventListener('scroll', (window as any).__headerScroll);
        (window as any).__headerScroll = onScroll;
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        // Mobile menu toggle
        const hamburger = document.getElementById('hamburger');
        const mobileMenu = document.getElementById('mobile-menu');

        // Reset mobile menu state on page change
        hamburger?.classList.remove('is-open');
        mobileMenu?.classList.remove('is-open');
        hamburger?.setAttribute('aria-expanded', 'false');
        mobileMenu?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';

        hamburger?.addEventListener('click', () => {
          const isOpen = hamburger.classList.toggle('is-open');
          mobileMenu?.classList.toggle('is-open', isOpen);
          hamburger.setAttribute('aria-expanded', String(isOpen));
          mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
          document.body.style.overflow = isOpen ? 'hidden' : '';
        });

        mobileMenu?.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            hamburger?.classList.remove('is-open');
            mobileMenu?.classList.remove('is-open');
            hamburger?.setAttribute('aria-expanded', 'false');
            mobileMenu?.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
          });
        });

        // Reveal on scroll — re-observe new page elements
        const reveals = document.querySelectorAll('.reveal:not(.is-visible)');
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        reveals.forEach(el => revealObserver.observe(el));
      });
    </script>
  </body>
</html>
