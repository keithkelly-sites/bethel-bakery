---
/*
  DESIGN CONCEPT: "Layered like their cakes"

  Inspired by Bernice Bakery's Awwwards-winning playful brand identity
  and the editorial typography of Magnolia Bakery (Gatefold + GT Alpina,
  documented on Fonts In Use). Bethel Bakery's identity IS layers —
  layers of buttercream, layers of generations, layers of 70 years in
  the same community. The founding year "1955" becomes monumental
  typography, the foundation everything is built on. Bodoni Moda's
  ultra-high-contrast hairlines at display sizes create drama that
  matches the craft and precision of their decorating work. Warm cream
  and dusty rose breathe through the navy, mirroring the color palette
  found in their own cake photography.

  Reference sites studied: Bernice Bakery (Awwwards HM), Fonts In Use
  bakery typography studies, Rick Sebak's documentary aesthetic for
  Pittsburgh heritage businesses.
*/
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import threeGenerationsImg from '../assets/images/three-generations.jpg';
import vintageFoundersImg from '../assets/images/vintage-founders.jpg';
import weddingCakeFlowersImg from '../assets/images/wedding-cake-flowers.jpg';
import cookieTableImg from '../assets/images/cookie-table.webp';
import goldCupcakeImg from '../assets/images/gold-cupcake.jpg';
import cakeLayersImg from '../assets/images/cake-layers.webp';
import pinkGoldTowerImg from '../assets/images/pink-gold-tower.jpg';
import monogramCookiesImg from '../assets/images/monogram-cookies.jpg';
import cupcakeTowerImg from '../assets/images/cupcake-tower.webp';
import bethelParkStoreImg from '../assets/images/bethel-park-store.jpg';
import northStrabaneStoreImg from '../assets/images/north-strabane-store.jpg';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Bakery",
  "name": "Bethel Bakery",
  "url": "https://bethel-bakery.keithkelly.dev",
  "telephone": "412-835-6658",
  "email": "info@bethelbakery.com",
  "foundingDate": "1955",
  "image": "https://bethel-bakery.keithkelly.dev/images/og-image.jpg",
  "description": "Three generations of the Walsh family have been baking life sweeter since 1955. Wedding cakes, custom cakes, cookies, cupcakes, and more.",
  "address": [
    {
      "@type": "PostalAddress",
      "streetAddress": "5200 Brightwood Road",
      "addressLocality": "Bethel Park",
      "addressRegion": "PA",
      "postalCode": "15102",
      "addressCountry": "US"
    },
    {
      "@type": "PostalAddress",
      "streetAddress": "2500 Washington Road",
      "addressLocality": "North Strabane",
      "addressRegion": "PA",
      "postalCode": "15317",
      "addressCountry": "US"
    }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "07:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "07:00",
      "closes": "17:00"
    }
  ],
  "sameAs": [
    "https://www.facebook.com/BethelBakery/",
    "https://www.instagram.com/bethelbakery/",
    "https://x.com/BethelBakery"
  ]
};
---
<Layout title="Bethel Bakery — Family-Owned Since 1955 | Bethel Park &amp; North Strabane, PA" description="Three generations of the Walsh family have been baking life sweeter since 1955. Wedding cakes, custom cakes, cookies, cupcakes, and more. Two locations in Pittsburgh's South Hills." darkHeader={true} canonicalPath="/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

<section class="hero" id="hero">
  <div class="hero-bg-year" aria-hidden="true">1955</div>
  <div class="hero-content">
    <div class="hero-text">
      <span class="hero-since">Since</span>
      <h1>1955</h1>
      <div class="hero-divider" aria-hidden="true"></div>
      <p class="hero-tagline">Three Generations of<br />Baking Life Sweeter</p>
      <div class="hero-actions">
        <a href="https://bethelbakery.bakesmart.com/" target="_blank" rel="noopener noreferrer" class="btn btn--outline">Order Online</a>
        <a href="/weddings" class="btn btn--rose">Plan Your Wedding</a>
      </div>
    </div>
    <div class="hero-image">
      <Image src={threeGenerationsImg} alt="Stephen Walsh, Morris Walsh, and John Walsh — three generations of Bethel Bakery bakers standing together outside the bakery" width={500} height={630} loading="eager" />
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<section class="origin">
  <div class="container">
    <div class="origin-grid">
      <div class="origin-photo reveal">
        <Image src={vintageFoundersImg} alt="Morris and Anna Walsh at Bethel Bakery, 1961" width={400} height={560} loading="lazy" />
        <span class="origin-year" aria-hidden="true">1955</span>
      </div>
      <div class="origin-text reveal reveal-delay-2">
        <h2>It started in<br />three garages</h2>
        <p>Morris "Moe" Walsh was orphaned at ten. After serving in the Navy, he put $2,500 together with his fiancee Anna and opened a bakery in three attached garages on South Park Road. Parking for two cars.</p>
        <p>He started every day at 2 a.m. Seventy years later, the bakery is still on Brightwood Road, still scratch-baking, and still run by the Walsh family. Stephen and Kate Walsh carry on what Morris and Anna started.</p>
        <a href="/about" class="text-link">Read our full story &rarr;</a>
      </div>
    </div>
  </div>
</section>

<section class="wedding-showcase">
  <div class="wedding-showcase-image">
    <Image src={weddingCakeFlowersImg} alt="A two-tier white wedding cake adorned with fresh flowers by Bethel Bakery" width={683} height={1024} loading="lazy" />
  </div>
  <div class="wedding-showcase-overlay" aria-hidden="true"></div>
  <div class="wedding-showcase-content reveal">
    <span class="section-label">Weddings</span>
    <h2>Your celebration,<br /><em>our craft</em></h2>
    <p>Custom wedding cakes, cupcake towers, cookie tables, and monogram cookies. Every detail made from scratch, planned through personal consultation.</p>
    <a href="/weddings" class="btn btn--outline">Explore Wedding Cakes</a>
  </div>
</section>

<section class="pittsburgh">
  <div class="container">
    <div class="pittsburgh-grid">
      <div class="pittsburgh-text reveal">
        <span class="section-label">Pittsburgh Pride</span>
        <h2>Part of Pittsburgh<br />since day one</h2>
        <p>Featured in Rick Sebak's WQED documentary "What Makes Pittsburgh, Pittsburgh." Officially licensed for the Terrible Towel cookie, with proceeds going to Merakey Allegheny Valley School.</p>
        <p>And of course, we do the cookie table. It's not a Pittsburgh wedding without one.</p>
      </div>
      <div class="pittsburgh-photo reveal reveal-delay-2">
        <Image src={cookieTableImg} alt="A Pittsburgh cookie table spread with cream horns and chocolate-dipped cookies at a Bethel Bakery wedding" width={819} height={1024} loading="lazy" />
      </div>
    </div>
  </div>
</section>

<section class="product-strip" aria-label="Product showcase">
  <div class="strip-track">
    <div class="strip-item">
      <Image src={goldCupcakeImg} alt="Gold crystalized sugar cupcake" width={400} height={560} loading="lazy" />
    </div>
    <div class="strip-item">
      <Image src={cakeLayersImg} alt="Layered cake cross-section" width={400} height={267} loading="lazy" />
    </div>
    <div class="strip-item">
      <Image src={pinkGoldTowerImg} alt="Pink and gold cupcake tower with cutting cake" width={400} height={560} loading="lazy" />
    </div>
    <div class="strip-item">
      <Image src={monogramCookiesImg} alt="Custom monogram wedding cookies" width={400} height={400} loading="lazy" />
    </div>
    <div class="strip-item">
      <Image src={cupcakeTowerImg} alt="Cupcake tower at outdoor reception" width={400} height={500} loading="lazy" />
    </div>
  </div>
</section>

<section class="locations-preview">
  <div class="container">
    <h2 class="locations-heading reveal">Two Locations in the South Hills</h2>
    <div class="locations-grid">
      <a href="/contact" class="location-preview-card reveal">
        <div class="lpc-image">
          <Image src={bethelParkStoreImg} alt="Bethel Bakery storefront in Bethel Park, Pennsylvania" width={768} height={586} loading="lazy" />
        </div>
        <div class="lpc-info">
          <h3>Bethel Park</h3>
          <p>5200 Brightwood Road</p>
          <p class="lpc-hours">Mon-Fri 7a-6p &middot; Sat 7a-5p</p>
        </div>
      </a>
      <a href="/contact" class="location-preview-card reveal reveal-delay-2">
        <div class="lpc-image">
          <Image src={northStrabaneStoreImg} alt="Bethel Bakery storefront in North Strabane, Pennsylvania" width={800} height={600} loading="lazy" />
        </div>
        <div class="lpc-info">
          <h3>North Strabane</h3>
          <p>2500 Washington Road</p>
          <p class="lpc-hours">Mon-Fri 8a-6p &middot; Sat 9a-5p</p>
        </div>
      </a>
    </div>
  </div>
</section>

<section class="home-cta">
  <div class="container">
    <div class="home-cta-inner reveal">
      <p class="home-cta-label">Ready to order?</p>
      <h2>Browse our full menu and<br />order online for pickup.</h2>
      <a href="https://bethelbakery.bakesmart.com/" target="_blank" rel="noopener noreferrer" class="btn btn--primary">Order Online</a>
      <p class="home-cta-phone">Or call <a href="tel:4128356658">412-835-6658</a></p>
    </div>
  </div>
</section>

</Layout>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--navy-deep);
    overflow: hidden;
    padding: 6rem var(--gutter) 3rem;
  }

  .hero-bg-year {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: clamp(20rem, 45vw, 50rem);
    font-weight: 900;
    color: var(--cream);
    opacity: 0.03;
    line-height: 0.85;
    letter-spacing: -0.02em;
    pointer-events: none;
    white-space: nowrap;
    user-select: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
    max-width: var(--max-width);
    width: 100%;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
  }

  .hero-since {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 0.5rem;
  }

  .hero h1 {
    font-size: clamp(6rem, 18vw, 14rem);
    font-weight: 900;
    color: var(--cream);
    line-height: 0.85;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .hero-divider {
    width: 60px;
    height: 1px;
    background: var(--rose-deep);
    margin-bottom: 1.5rem;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    font-style: italic;
    color: color-mix(in oklch, var(--cream) 70%, transparent);
    line-height: 1.3;
    margin-bottom: var(--space-lg);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-image {
    display: flex;
    justify-content: center;
  }

  .hero-image img {
    width: 100%;
    max-width: 420px;
    border-radius: 8px;
    box-shadow: 0 20px 60px oklch(0.1 0.05 250 / 0.4);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
  }

  .hero-scroll span {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--cream) 30%, transparent);
  }

  .hero-scroll-line {
    width: 1px;
    height: 30px;
    background: linear-gradient(to bottom, var(--rose-deep), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.3); }
  }

  .origin {
    padding: var(--space-2xl) 0;
  }

  .origin-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .origin-photo {
    position: relative;
  }

  .origin-photo img {
    width: 100%;
    border-radius: 6px;
    filter: sepia(0.15) saturate(0.9);
  }

  .origin-year {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    font-family: var(--font-display);
    font-size: clamp(5rem, 10vw, 8rem);
    font-weight: 900;
    color: var(--rose-deep);
    opacity: 0.15;
    line-height: 1;
    pointer-events: none;
  }

  .origin-text h2 {
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
    color: var(--text);
    margin-bottom: var(--space-md);
    font-style: italic;
  }

  .origin-text p {
    color: var(--text-mid);
    margin-bottom: 1rem;
    max-width: 48ch;
    line-height: 1.75;
  }

  .text-link {
    display: inline-block;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--navy);
    margin-top: 0.5rem;
  }

  .text-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .wedding-showcase {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .wedding-showcase-image {
    position: absolute;
    inset: 0;
  }

  .wedding-showcase-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .wedding-showcase-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      oklch(0.15 0.05 250 / 0.9) 0%,
      oklch(0.15 0.05 250 / 0.55) 40%,
      oklch(0.15 0.05 250 / 0.2) 100%
    );
    z-index: 1;
  }

  .wedding-showcase-content {
    position: relative;
    z-index: 2;
    padding: var(--space-xl) var(--gutter);
    max-width: var(--max-width);
    margin-inline: auto;
    width: 100%;
  }

  .section-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: var(--space-sm);
  }

  .wedding-showcase-content h2 {
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    color: var(--cream);
    margin-bottom: var(--space-md);
  }

  .wedding-showcase-content h2 em {
    font-style: italic;
    color: var(--rose);
  }

  .wedding-showcase-content p {
    font-size: 1.05rem;
    color: color-mix(in oklch, var(--cream) 70%, transparent);
    max-width: 44ch;
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  .pittsburgh {
    padding: var(--space-2xl) 0;
    background: var(--cream-dark);
  }

  .pittsburgh-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .pittsburgh-text h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--text);
    margin-bottom: var(--space-md);
    font-style: italic;
  }

  .pittsburgh-text p {
    color: var(--text-mid);
    margin-bottom: 1rem;
    max-width: 44ch;
    line-height: 1.75;
  }

  .pittsburgh-photo img {
    width: 100%;
    border-radius: 8px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .product-strip {
    padding: var(--space-lg) 0;
    overflow: hidden;
  }

  .strip-track {
    display: flex;
    gap: 1rem;
    padding-inline: var(--gutter);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .strip-track::-webkit-scrollbar { display: none; }

  .strip-item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    border-radius: 8px;
    overflow: hidden;
  }

  .strip-item img {
    height: clamp(200px, 30vh, 320px);
    width: auto;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .strip-item:hover img {
    transform: scale(1.04);
  }

  .locations-preview {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .locations-heading {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    color: var(--text);
    text-align: center;
    margin-bottom: var(--space-xl);
    font-style: italic;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .location-preview-card {
    display: block;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 16px color-mix(in oklch, var(--navy) 5%, transparent);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .location-preview-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px color-mix(in oklch, var(--navy) 10%, transparent);
  }

  .lpc-image {
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .lpc-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .location-preview-card:hover .lpc-image img {
    transform: scale(1.04);
  }

  .lpc-info {
    padding: 1.25rem 1.5rem;
  }

  .lpc-info h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .lpc-info p {
    font-size: 0.9rem;
    color: var(--text-mid);
  }

  .lpc-hours {
    font-size: 0.8rem;
    color: var(--text-light);
    margin-top: 0.4rem;
  }

  .home-cta {
    padding: var(--space-2xl) 0;
    background: var(--rose);
  }

  .home-cta-inner {
    text-align: center;
  }

  .home-cta-label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--navy);
    margin-bottom: var(--space-sm);
  }

  .home-cta-inner h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--text);
    margin-bottom: var(--space-lg);
    font-style: italic;
  }

  .home-cta-phone {
    margin-top: var(--space-md);
    color: var(--text-mid);
    font-size: 0.95rem;
  }

  .home-cta-phone a {
    font-weight: 600;
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 8rem var(--gutter) 4rem;
    }

    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-text { align-items: center; }

    .hero h1 {
      font-size: clamp(5rem, 22vw, 8rem);
    }

    .hero-divider { margin-inline: auto; }

    .hero-actions { justify-content: center; }

    .hero-image {
      order: -1;
    }

    .hero-image img {
      max-width: 280px;
      margin-inline: auto;
    }

    .hero-bg-year {
      font-size: clamp(10rem, 50vw, 20rem);
    }

    .hero-scroll { display: none; }

    .origin-grid {
      grid-template-columns: 1fr;
    }

    .origin-photo {
      max-width: 300px;
      margin-inline: auto;
    }

    .origin-text { text-align: left; }

    .wedding-showcase { min-height: 70vh; }

    .pittsburgh-grid { grid-template-columns: 1fr; }

    .pittsburgh-photo { order: -1; }

    .locations-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Parallax on hero background year
  const bgYear = document.querySelector('.hero-bg-year');
  if (bgYear instanceof HTMLElement) {
    const mql = window.matchMedia('(prefers-reduced-motion: no-preference)');
    if (mql.matches) {
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const rate = scrollY * 0.15;
        bgYear.style.transform = `translate(-50%, calc(-50% + ${rate}px))`;
      }, { passive: true });
    }
  }
</script>
